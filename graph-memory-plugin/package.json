{
  "name": "graph-memory",
  "version": "2.0.0",
  "type": "module",
  "description": "Persistent, self-evolving memory for AI agents. A Claude Code plugin that gives any agent a knowledge graph.",
  "license": "MIT",
  "main": "dist/graph-memory/mcp-server.js",
  "bin": {
    "graph-memory": "dist/graph-memory/mcp-server.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-prompts",
    "copy-prompts": "rm -rf dist/graph-memory/prompts && cp -r src/graph-memory/prompts dist/graph-memory/prompts",
    "dev": "tsc --watch",
    "mcp": "node dist/graph-memory/mcp-server.js",
    "postinstall": "[ -d dist ] || npm run build",
    "prepublishOnly": "npm test",
    "status": "node -e \"import('./dist/graph-memory/tools.js').then(m => m.handleGraphMemory({action:'status'}).then(r => console.log(r.content[0].text)))\"",
    "test": "npm run build && node --test tests/*.check.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "simple-git": "^3.36.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.37",
    "typescript": "^5.6.0"
  },
  "files": [
    "dist/",
    "bin/",
    "docker/",
    "commands/",
    "agents/",
    "skills/",
    "hooks/",
    ".claude-plugin/",
    "LICENSE"
  ]
}
