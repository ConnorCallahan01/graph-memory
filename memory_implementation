    <Code title="Session boundary detection — src/session/manager.ts" color={C.amber}>
{`SESSION DETECTION STRATEGY:

A "session" is defined by IDLE GAPS, not by explicit 
start/end commands. This mirrors how humans experience 
conversational boundaries — you don't announce "I'm 
starting a conversation" and "I'm ending a conversation." 
You just... stop talking for a while.

RULES:
1. Session STARTS on first message after:
   - System boot
   - Previous session ended
   - Graph was updated (new MAP available)

2. Session ENDS when ANY of:
   - 5 minutes of idle (no messages in either direction)
   - User explicitly says "done" / "that's it" / "thanks"
   - 200 messages reached (force boundary for graph health)
   - Claude Code process exits

3. Session TRANSITIONS (the critical UX moment):
   When a session ends:
   a) Pipeline runs (librarian + dreamer) — ~5-10 seconds
   b) Graph updates are written
   c) Git commit + push happens
   d) New PRIORS + MAP are ready
   
   When the user sends the next message:
   a) System detects: "new session" (idle gap exceeded)
   b) Loads fresh PRIORS + MAP into agent context
   c) Agent now has updated memory — seamlessly
   
   THE USER NEVER NOTICES. There is no "loading memory" 
   message. No "session starting" indicator. The agent 
   just... knows more than it did before the gap.`}
    </Code>

    <Label color={C.amber}>The Message Buffer and Scribe Trigger</Label>
    <Code title="src/session/message-buffer.ts" color={C.amber}>
{`// Dependency: @anthropic-ai/sdk (npm install)
// const Anthropic = require("@anthropic-ai/sdk")

interface MessageEntry {
  role: "user" | "assistant";
  content: string;
  timestamp: number;
}

class MessageBuffer {
  private buffer: MessageEntry[] = [];
  private scribeQueue: Promise[] = [];  // Promise<void>
  private summaryChain: string[] = [];
  private messageCount = 0;
  private sessionId: string;
  
  constructor(sessionId: string) {
    this.sessionId = sessionId;
  }

  // Called on every message (user or assistant)
  async push(entry: MessageEntry) {
    this.buffer.push(entry);
    this.messageCount++;

    // Every N messages, fire a scribe IN PARALLEL
    if (this.buffer.length >= CONFIG.session.scribeInterval) {
      const fragment = [...this.buffer];
      this.buffer = []; // Reset buffer immediately
      
      // Scribe runs async — does NOT block conversation
      const scribePromise = this.fireScribe(fragment);
      this.scribeQueue.push(scribePromise);
    }
  }

  private async fireScribe(fragment: MessageEntry[]) {
    const client = new Anthropic();
    
    const response = await client.messages.create({
      model: CONFIG.models.scribe,
      max_tokens: 1000,
      temperature: CONFIG.temperature.scribe,
      system: SCRIBE_PROMPT,
      messages: [{
        role: "user",
        content: buildScribeInput({
          map: getCurrentMap(),
          summaryChain: this.summaryChain,
          fragment,
        })
      }],
    });

    const output = parseScribeOutput(response);
    
    // Append summary to chain for next scribe
    this.summaryChain.push(output.summary);
    
    // Append deltas to session delta file
    appendDeltas(this.sessionId, output.deltas);
  }

  // Called when session ends — wait for all scribes
  async flush(): Promise {  // Promise<void>
    await Promise.all(this.scribeQueue);
    
    // Fire final scribe for remaining buffer
    if (this.buffer.length > 0) {
      await this.fireScribe([...this.buffer]);
      this.buffer = [];
    }
  }
}

// KEY INSIGHT: Scribes are fire-and-forget during conversation.
// They run in background Promise chains. The main conversation 
// thread is NEVER blocked. The only time we await them is at 
// session end, before the Librarian runs.`}
