    <Label color={C.purple}>Implementation</Label>
    <Code title="src/git/auto-commit.ts — core logic" color={C.purple}>
{`// Dependency: simple-git (npm install)
// const simpleGit = require("simple-git")

const git = simpleGit(CONFIG.paths.graphRoot);

export async function autoCommit(sessionId: string) {
  // 1. Stage all graph changes
  await git.add(".");
  
  // 2. Check if there are changes to commit
  const status = await git.status();
  if (status.isClean()) return;
  
  // 3. Build commit message from diff
  const diff = await git.diff(["--stat", "--cached"]);
  const message = buildCommitMessage(sessionId, status, diff);
  
  // 4. Commit
  await git.commit(message);
  
  // 5. Push (non-blocking)
  if (CONFIG.git.autoPush) {
    git.push(CONFIG.git.remote, CONFIG.git.branch)
      .catch(err => console.warn("Push failed:", err.message));
  }
}

function buildCommitMessage(
  sessionId: string, 
  status: StatusResult, 
  diff: string
): string {
  const created = status.created
    .filter(f => f.startsWith("nodes/"));
  const modified = status.modified
    .filter(f => f.startsWith("nodes/"));
  const renamed = status.renamed
    .filter(f => f.to.startsWith("archive/")); // archived
  
  const parts = [
    "memory: session " + sessionId,
    "  " + modified.length + " updated, ",
    "  " + created.length + " new, ",
    "  " + renamed.length + " archived",
  ];
  
  if (created.length) {
    parts.push("\\nNew:");
    created.forEach(f => parts.push("  + " + f));
  }
  if (modified.length) {
    parts.push("\\nUpdated:");
    modified.forEach(f => parts.push("  ~ " + f));
  }
  
  return parts.join("\\n");
}`}
