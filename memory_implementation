    <Label color={C.accent}>The Index — How Search Works Without Embeddings</Label>
    <Code title="src/graph/index-builder.ts" color={C.accent}>
{`// .index.json is rebuilt after every librarian run
// It's a flat lookup optimized for fast text search

interface IndexEntry {
  path: string;
  gist: string;
  tags: string[];          // extracted from frontmatter
  keywords: string[];      // extracted from gist + title
  edges: string[];         // target paths
  anti_edges: string[];
  confidence: number;
  soma_intensity: number;
  last_accessed: string;
  access_count: number;
}

// Search algorithm — no vector DB needed
function search(query: string, index: IndexEntry[]): SearchResult[] {
  const queryTokens = tokenize(query.toLowerCase());
  
  return index
    .map(entry => {
      // Score = weighted combination of matches
      const gistScore = overlap(queryTokens, 
        tokenize(entry.gist)) * 3;         // gist weighted 3x
      const tagScore = overlap(queryTokens, 
        entry.tags) * 2;                    // tags weighted 2x
      const keywordScore = overlap(queryTokens, 
        entry.keywords) * 1;               // keywords 1x
      
      // Boost by confidence and recency
      const relevance = (gistScore + tagScore + keywordScore) 
        * entry.confidence 
        * recencyBoost(entry.last_accessed);
      
      return { path: entry.path, relevance, gist: entry.gist };
    })
    .filter(r => r.relevance > 0.1)
    .sort((a, b) => b.relevance - a.relevance)
    .slice(0, 5);
}

// WHY NO EMBEDDINGS:
// 1. The graph is small (50-100 nodes). Linear scan is <1ms.
// 2. Keyword overlap on curated gists is surprisingly accurate.
// 3. No dependency on embedding models or vector DBs.
// 4. The index rebuilds in <100ms — no incremental update complexity.
// 5. If you WANT embeddings later, swap search() — the rest is unchanged.`}
